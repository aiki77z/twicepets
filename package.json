{
  "name": "twice-pets",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop pet shell wired to nine finalized TWICE pet atlases.",
  "author": "TWICE Pets",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "serve:ipad": "python -m http.server 4173 --bind 0.0.0.0",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.twice.desktoppets",
    "productName": "TWICE Pets",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.js",
      "build/icon.ico",
      "build/icon.icns",
      "index.html",
      "main.js",
      "package.json",
      "pet-data.js",
      "preload.js",
      "styles.css",
      "navely/hatch-run/final/spritesheet.webp",
      "jeongvely/hatch-run/final/spritesheet.webp",
      "movely/hatch-run/final/spritesheet.webp",
      "savely/hatch-run/final/spritesheet.webp",
      "jively/hatch-run/final/spritesheet.webp",
      "mively/hatch-run/final/spritesheet.webp",
      "davely/hatch-run/final/spritesheet.webp",
      "chaengvely/hatch-run/final/spritesheet.webp",
      "tsuvely/hatch-run/final/spritesheet.webp"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "icon.icns"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "TWICE-Pets-win11-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "TWICE-Pets-win11-${version}.${ext}"
    }
  }
}
